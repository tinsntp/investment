<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Budget Area Chart</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { width: 100%; height: 100%; font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif; color: #fff; overflow: hidden; }
  body { position: relative; }
  #status { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); font-size: 1.8vw; color: rgba(255,255,255,0.4); text-align: center; line-height: 2; white-space: pre-line; }
  #chart-wrap { position: absolute; bottom: 0; left: 0; right: 0; padding: 0 4vw 3vw; display: none; }
</style>
</head>
<body>

<div id="status">Loading…</div>
<div id="chart-wrap">
  <svg id="chart-svg" width="100%" xmlns="http://www.w3.org/2000/svg"></svg>
</div>

<script>
  const CSV_URL = `https://docs.google.com/spreadsheets/d/e/2PACX-1vQnzbOhfKNO_niIpBIoReyDiy5p-UdXvtO6SIMNKXrZts9Cax9hR_5F7RqB_uejrjZuyV6N-Pjc08kd/pub?output=csv`;

  const COLOR_NEG_FILL   = 'rgba(200,200,200,0.15)';
  const COLOR_NEG_STROKE = '#c8c8c8';
  const COLOR_POS_FILL   = 'rgba(77,182,172,0.2)';
  const COLOR_POS_STROKE = '#4DB6AC';

  function fmt(v) {
    const a = Math.abs(v);
    let s = a >= 1e6 ? (a/1e6).toFixed(1).replace(/\.0$/,'')+'M'
          : a >= 1e3 ? (a/1e3).toFixed(0)+'K'
          : String(a);
    return (v < 0 ? '−' : '') + s;
  }

  function setStatus(msg) {
    const el = document.getElementById('status');
    el.style.display = 'block';
    el.textContent = msg;
  }

  function splitCSVRow(row) {
    const cols = []; let cur = '', inQ = false;
    for (const ch of row) {
      if (ch === '"') inQ = !inQ;
      else if (ch === ',' && !inQ) { cols.push(cur); cur = ''; }
      else cur += ch;
    }
    cols.push(cur);
    return cols;
  }

  function parseNum(str) {
    if (!str) return NaN;
    let s = str.trim();
    const isAcct = /^\(.*\)$/.test(s);
    if (isAcct) s = '-' + s.slice(1,-1);
    s = s.replace(/[\u2212\u2013\u2014]/g, '-').replace(/[^0-9.\-]/g, '');
    return parseFloat(s);
  }

  async function fetchData() {
    const r = await fetch(CSV_URL + '&t=' + Date.now(), { cache: 'no-store' });
    if (!r.ok) throw new Error(`HTTP ${r.status}`);
    const text = await r.text();
    const rows = text.trim().split('\n').slice(1);
    const data = rows.map(row => {
      const cols = splitCSVRow(row);
      const name = cols[0].replace(/^"|"$/g,'').trim();
      const val  = parseNum(cols[1]);
      return { name, val };
    }).filter(d => d.name && !isNaN(d.val));
    if (!data.length) throw new Error('No valid data rows found.');
    return data;
  }

  function render(data) {
    const VW = window.innerWidth;
    const W  = VW - VW * 0.08; // account for 4vw padding each side

    // Layout zones (all in SVG units = px at current width):
    // [0 .. topPad] = space for positive value labels
    // [topPad .. baseline] = positive bars area
    // [baseline] = x-axis line
    // [baseline .. baseline+negH] = negative bars area
    // [baseline+negH .. baseline+negH+labelPad] = gap
    // [baseline+negH+labelPad .. H] = category name labels

    const fontSize     = VW * 0.02;
    const lineH        = fontSize * 1.4;
    const topPad       = VW * 0.05;   // room for pos value labels
    const chartZone    = VW * 0.28;   // total height for pos+neg bars
    const baseline     = topPad + chartZone * 0.42;
    const negZoneH     = chartZone * 0.58;
    const labelPad     = VW * 0.015;  // gap between last neg bar and name label
    const labelLines   = 2;           // max lines per label
    const H            = baseline + negZoneH + labelPad + lineH * labelLines + VW * 0.01;

    const scaleUp   = (baseline - topPad) * 0.92;  // max positive bar height
    const scaleDown = negZoneH * 0.92;              // max negative bar height
    const maxPos    = Math.max(...data.map(d => d.val > 0 ? d.val : 0), 1);
    const maxNeg    = Math.max(...data.map(d => d.val < 0 ? Math.abs(d.val) : 0), 1);

    const svg = document.getElementById('chart-svg');
    svg.setAttribute('viewBox', `0 0 ${W} ${H}`);
    svg.setAttribute('height', H);
    svg.innerHTML = '';

    const n     = data.length;
    const xStep = W / (n - 1);
    const dotR  = VW * 0.007;

    const pts = data.map((d, i) => {
      const x = i * xStep;
      const y = d.val >= 0
        ? baseline - (d.val / maxPos) * scaleUp
        : baseline + (Math.abs(d.val) / maxNeg) * scaleDown;
      return { x, y, ...d };
    });

    // ── Clip paths ──────────────────────────────────────────────────────
    const defs = document.createElementNS('http://www.w3.org/2000/svg','defs');

    function makeClip(id, y, h) {
      const clip = document.createElementNS('http://www.w3.org/2000/svg','clipPath');
      clip.setAttribute('id', id);
      const r = document.createElementNS('http://www.w3.org/2000/svg','rect');
      r.setAttribute('x','0'); r.setAttribute('y', y);
      r.setAttribute('width', W); r.setAttribute('height', h);
      clip.appendChild(r);
      return clip;
    }
    defs.appendChild(makeClip('clip-pos', 0, baseline));
    defs.appendChild(makeClip('clip-neg', baseline, H - baseline));
    svg.appendChild(defs);

    // ── Area + stroke paths ─────────────────────────────────────────────
    function curvePath(points) {
      let d = `M ${points[0].x} ${points[0].y}`;
      for (let i = 1; i < points.length; i++) {
        const p = points[i-1], c = points[i];
        const cx = (p.x + c.x) / 2;
        d += ` C ${cx} ${p.y} ${cx} ${c.y} ${c.x} ${c.y}`;
      }
      return d;
    }

    const linePath = curvePath(pts);
    const areaPath = linePath + ` L ${pts[pts.length-1].x} ${baseline} L ${pts[0].x} ${baseline} Z`;

    function addPath(d, fill, stroke, clip) {
      const p = document.createElementNS('http://www.w3.org/2000/svg','path');
      p.setAttribute('d', d);
      p.setAttribute('fill', fill || 'none');
      if (stroke) { p.setAttribute('stroke', stroke); p.setAttribute('stroke-width', VW * 0.003); p.setAttribute('stroke-linejoin','round'); p.setAttribute('stroke-linecap','round'); }
      if (clip) p.setAttribute('clip-path', `url(#${clip})`);
      svg.appendChild(p);
    }

    addPath(areaPath, COLOR_NEG_FILL, null, 'clip-neg');
    addPath(areaPath, COLOR_POS_FILL, null, 'clip-pos');

    // Baseline rule
    const bl = document.createElementNS('http://www.w3.org/2000/svg','line');
    bl.setAttribute('x1','0'); bl.setAttribute('y1', baseline);
    bl.setAttribute('x2', W); bl.setAttribute('y2', baseline);
    bl.setAttribute('stroke','rgba(255,255,255,0.25)'); bl.setAttribute('stroke-width','1.5');
    svg.appendChild(bl);

    addPath(linePath, 'none', COLOR_NEG_STROKE, 'clip-neg');
    addPath(linePath, 'none', COLOR_POS_STROKE, 'clip-pos');

    // ── Dots + value labels ─────────────────────────────────────────────
    pts.forEach(({ x, y, val }) => {
      const isPos  = val >= 0;
      const stroke = isPos ? COLOR_POS_STROKE : COLOR_NEG_STROKE;
      const valOff = VW * 0.022;

      const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');
      circle.setAttribute('cx', x); circle.setAttribute('cy', y);
      circle.setAttribute('r', dotR);
      circle.setAttribute('fill', 'transparent');
      circle.setAttribute('stroke', stroke);
      circle.setAttribute('stroke-width', VW * 0.002);
      svg.appendChild(circle);

      const t = document.createElementNS('http://www.w3.org/2000/svg','text');
      t.setAttribute('x', x);
      t.setAttribute('y', isPos ? y - valOff * 0.4 : y + valOff);
      t.setAttribute('text-anchor','middle');
      t.setAttribute('fill','#fff');
      t.setAttribute('font-size', VW * 0.022);
      t.setAttribute('font-family','-apple-system,BlinkMacSystemFont,sans-serif');
      t.textContent = fmt(val);
      svg.appendChild(t);
    });

    // ── X-axis category name labels ─────────────────────────────────────
    // Negative: above baseline | Positive: below baseline
    // Long names are word-wrapped to fit within each column slot
    const slotW    = W / n;           // width available per label
    const charW    = fontSize * 0.6;  // approx char width
    const maxChars = Math.floor(slotW / charW);

    function wrapText(text, maxCh) {
      // first respect explicit newlines
      const hardLines = text.split(/\n|\\n/);
      const out = [];
      hardLines.forEach(seg => {
        const words = seg.split(' ');
        let line = '';
        words.forEach(word => {
          if ((line + ' ' + word).trim().length <= maxCh) {
            line = (line + ' ' + word).trim();
          } else {
            if (line) out.push(line);
            line = word;
          }
        });
        if (line) out.push(line);
      });
      return out;
    }

    const gap = VW * 0.012;

    pts.forEach(({ x, val, name }) => {
      const isPos = val >= 0;
      const lines = wrapText(name, maxChars);

      let startY;
      if (isPos) {
        // below baseline: top of first line = baseline + gap
        startY = baseline + gap + fontSize;
      } else {
        // above baseline: bottom of last line = baseline - gap
        const blockH = lines.length * lineH;
        startY = baseline - gap - blockH + fontSize;
      }

      lines.forEach((line, li) => {
        const t = document.createElementNS('http://www.w3.org/2000/svg','text');
        t.setAttribute('x', x);
        t.setAttribute('y', startY + li * lineH);
        t.setAttribute('text-anchor','middle');
        t.setAttribute('fill','rgba(255,255,255,0.75)');
        t.setAttribute('font-size', fontSize);
        t.setAttribute('font-family','-apple-system,BlinkMacSystemFont,sans-serif');
        t.textContent = line;
        svg.appendChild(t);
      });
    });

    document.getElementById('status').style.display = 'none';
    document.getElementById('chart-wrap').style.display = 'block';
  }

  async function load() {
    setStatus('Loading…');
    try {
      const data = await fetchData();
      render(data);
    } catch(e) {
      setStatus(`⚠ Failed to load data\n${e.message}`);
    }
  }

  load();
  setInterval(load, 60000);
  window.addEventListener('resize', load);
</script>
</body>
</html>
